---
const steps = [
  {
    number: '01',
    title: 'Chame pelo app',
    detail: 'Peça a entrega direto no aplicativo, sem burocracia.',
  },
  {
    number: '02',
    title: 'Motoboy busca o produto',
    detail: 'Ele vai até sua loja pegar o que precisa ser entregue.',
  },
  {
    number: '03',
    title: 'Entrega no cliente',
    detail: 'Você paga só essa corrida — sem mensalidade, sem fidelidade.',
  },
];
---

<section class="pricing" id="precos" aria-labelledby="pricing-title">
  <div class="pricing__container">

    <div class="pricing__header">
      <p class="eyebrow reveal">Para o seu negócio</p>
      <h2 class="section-title reveal delay-1" id="pricing-title">
        Seu negócio chama,<br />a gente entrega.
      </h2>
    </div>

    <div class="pricing__steps">
      {steps.map((s, i) => (
        <div class="pstep reveal" style={`transition-delay: ${(i + 1) * 0.1}s`}>
          <span class="pstep__number mono" aria-hidden="true">{s.number}</span>
          <h3 class="pstep__title">{s.title}</h3>
          <p class="pstep__detail">{s.detail}</p>

          {i < steps.length - 1 && (
            <div class="pstep__connector" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
                <path
                  d="M3 8h10M9 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .pricing {
    padding: var(--section-pad-y) var(--section-pad-x);
    position: relative;
  }

  .pricing__container {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .pricing__header {
    margin-bottom: 3.5rem;
  }

  .pricing__steps {
    display: flex;
    align-items: stretch;
    gap: 1.5rem;
  }

  .pstep {
    flex: 1;
    min-width: 0;
    position: relative;
    background: linear-gradient(145deg, rgba(242, 240, 234, 0.04) 0%, rgba(242, 240, 234, 0.01) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.75rem 1.5rem;
    transition: transform 0.3s var(--ease-out-expo), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .pstep::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    background: linear-gradient(90deg, var(--accent), transparent 80%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s var(--ease-out-expo);
  }

  .pstep:hover {
    transform: translateY(-4px);
    border-color: rgba(244, 194, 13, 0.3);
    box-shadow: 0 15px 35px -15px rgba(0, 0, 0, 0.5);
  }

  .pstep:hover::before {
    transform: scaleX(1);
  }

  .pstep__number {
    display: block;
    font-size: 0.8125rem;
    color: var(--muted);
    opacity: 0.5;
    margin-bottom: 1rem;
  }

  .pstep__title {
    font-size: 1.0625rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .pstep__detail {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .pstep__connector {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translate(50%, -50%);
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--accent);
    z-index: 2;
  }

  @media (max-width: 860px) {
    .pricing__steps {
      flex-direction: column;
      gap: 1.5rem;
    }

    .pstep__connector {
      top: auto;
      right: auto;
      bottom: 0;
      left: 50%;
      transform: translate(-50%, 50%) rotate(90deg);
    }
  }

  @media (max-width: 480px) {
    .pricing__header {
      margin-bottom: 2.5rem;
    }

    .pstep {
      padding: 1.5rem 1.25rem;
    }

    .pstep__title {
      font-size: 1rem;
    }

    .pstep__detail {
      font-size: 0.875rem;
    }
  }
</style>
