---
---

<section class="pricing" id="precos" aria-labelledby="pricing-title">
  <div class="pricing__container">

    <div class="pricing__header">
      <p class="eyebrow reveal">Transparência total</p>
      <h2 class="section-title reveal delay-1" id="pricing-title">
        Preço claro,<br />sem letra pequena.
      </h2>
    </div>

    <!-- Price display — panel de instrumento -->
    <div class="pricing__panel reveal delay-2" role="region" aria-label="Valor mínimo por corrida">
      <div class="pricing__panel-header">
        <span class="pricing__panel-label">Piso por corrida</span>
        <span class="pricing__panel-status" aria-hidden="true">● ATIVO</span>
      </div>

      <div class="pricing__display">
        <span class="pricing__currency mono">R$</span>
        <span class="pricing__value mono" data-counter="10" aria-label="10 reais">10</span>
      </div>

      <div class="pricing__panel-footer">
        <p class="pricing__main">
          Você vê o valor exato antes de confirmar — nunca depois.
        </p>
      </div>
    </div>

    <p class="pricing__support reveal delay-3">
      Sem depender de quanto o motoboy "sente" que deve cobrar naquele dia.
    </p>

    <!-- Trust indicators -->
    <div class="pricing__trust reveal delay-4">
      <div class="pricing__trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span>Preço travado ao confirmar</span>
      </div>
      <div class="pricing__trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        <span>Sem cobrança por espera</span>
      </div>
      <div class="pricing__trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
          <line x1="1" y1="10" x2="23" y2="10"/>
        </svg>
        <span>Pagamento 100% digital</span>
      </div>
    </div>

  </div>
</section>

<style>
  .pricing {
    padding: var(--section-pad-y) var(--section-pad-x);
    position: relative;
  }

  .pricing__container {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .pricing__header {
    margin-bottom: 3rem;
  }

  /* Panel display */
  .pricing__panel {
    background: var(--surface);
    border: 1px solid var(--border-solid);
    border-radius: var(--radius-md);
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    display: inline-block;
    max-width: 380px;
    width: 100%;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .pricing__panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
  }

  .pricing__panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .pricing__panel-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .pricing__panel-status {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    color: #4ade80;
    letter-spacing: 0.08em;
  }

  .pricing__display {
    padding: 2rem 1.5rem 1.5rem;
    display: flex;
    align-items: flex-start;
  }

  .pricing__currency {
    font-size: 1.5rem;
    color: var(--accent);
    opacity: 0.6;
    margin-top: 0.75rem;
    margin-right: 0.25rem;
    line-height: 1;
  }

  .pricing__value {
    font-size: clamp(4rem, 10vw, 6rem);
    color: var(--accent);
    line-height: 1;
  }

  .pricing__panel-footer {
    padding: 0 1.5rem 1.5rem;
  }

  .pricing__main {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* Support text */
  .pricing__support {
    font-size: 1rem;
    color: var(--muted);
    font-style: italic;
    margin-bottom: 3rem;
    max-width: 480px;
  }

  /* Trust indicators */
  .pricing__trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .pricing__trust-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: var(--muted);
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.25s ease, color 0.25s ease;
  }

  .pricing__trust-item:hover {
    border-color: rgba(244, 194, 13, 0.25);
    color: var(--text);
  }

  .pricing__trust-item svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .pricing__trust {
      grid-template-columns: 1fr 1fr;
    }
    .pricing__trust-item:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .pricing__trust {
      grid-template-columns: 1fr;
    }
    .pricing__trust-item:last-child {
      grid-column: auto;
    }
  }
</style>
