---
const steps = [
  {
    number: '01',
    title: 'Peça e diga onde você está.',
    detail: 'Abra o app, confirme sua localização.',
    icon: '<path d="M12 21s7-6.8 7-12a7 7 0 1 0-14 0c0 5.2 7 12 7 12z"/><circle cx="12" cy="9" r="2.5"/>',
  },
  {
    number: '02',
    title: 'Veja o preço antes de confirmar.',
    detail: 'Sem surpresa, sem negociar — o valor aparece antes de você aceitar.',
    icon: '<path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3"/>',
  },
  {
    number: '03',
    title: 'Acompanhe a moto chegando até você.',
    detail: 'Rastreio em tempo real. Você sabe exatamente onde está o motoboy.',
    icon: '<polygon points="3 11 22 2 13 21 11 13 3 11"/>',
  },
  {
    number: '04',
    title: 'Pague direto no aplicativo.',
    detail: 'Pagamento digital, seguro, sem troco, sem risco.',
    icon: '<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>',
  },
];
---

<section class="how" id="como-funciona" aria-labelledby="how-title">
  <div class="how__container">

    <div class="how__header">
      <p class="eyebrow reveal">Corridas e entregas</p>
      <h2 class="section-title reveal delay-1" id="how-title">
        Do celular até você —<br />ou até seu endereço.
      </h2>
    </div>

    <div class="how__steps">
      {steps.map((step, i) => (
        <div class="step reveal" style={`transition-delay: ${(i + 1) * 0.1}s`}>
          <div class="step__top">
            <div class="step__icon" aria-hidden="true">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={step.icon}
              />
            </div>
            <span class="step__number mono" aria-hidden="true">{step.number}</span>
          </div>
          <h3 class="step__title">{step.title}</h3>
          <p class="step__detail">{step.detail}</p>

          {i < steps.length - 1 && (
            <div class="step__connector" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
                <path
                  d="M3 8h10M9 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="how__closing reveal">
      <svg
        class="how__closing-icon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M20 6 9 17l-5-5"></path>
      </svg>
      <p class="how__closing-text">
        Você sabe exatamente o que vai pagar e quando a moto chega.
        <strong>Simples assim.</strong>
      </p>
    </div>

  </div>
</section>

<style>
  .how {
    padding: var(--section-pad-y) var(--section-pad-x);
    position: relative;
  }

  .how__container {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .how__header {
    margin-bottom: 3.5rem;
  }

  /* Steps */
  .how__steps {
    display: flex;
    align-items: stretch;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  .step {
    flex: 1;
    min-width: 0;
    position: relative;
    background: linear-gradient(145deg, rgba(242, 240, 234, 0.04) 0%, rgba(242, 240, 234, 0.01) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.75rem 1.5rem;
    transition: transform 0.3s var(--ease-out-expo), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .step::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    background: linear-gradient(90deg, var(--accent), transparent 80%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s var(--ease-out-expo);
  }

  .step:hover {
    transform: translateY(-4px);
    border-color: rgba(244, 194, 13, 0.3);
    box-shadow: 0 15px 35px -15px rgba(0, 0, 0, 0.5);
  }

  .step:hover::before {
    transform: scaleX(1);
  }

  .step__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .step__icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: rgba(244, 194, 13, 0.08);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s ease, transform 0.3s var(--ease-spring);
  }

  .step:hover .step__icon {
    background: rgba(244, 194, 13, 0.16);
    transform: scale(1.06) rotate(-4deg);
  }

  .step__number {
    font-size: 0.8125rem;
    color: var(--muted);
    opacity: 0.5;
    letter-spacing: 0.02em;
  }

  .step__title {
    font-size: 1.0625rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .step__detail {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* Connector — sits astride the boundary between two cards */
  .step__connector {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translate(50%, -50%);
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--accent);
    z-index: 2;
  }

  /* Closing */
  .how__closing {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
  }

  .how__closing-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    padding: 0.5rem;
    box-sizing: border-box;
    border-radius: 50%;
    background: rgba(244, 194, 13, 0.1);
    color: var(--accent);
  }

  .how__closing-text {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .how__closing-text strong {
    color: var(--text);
  }

  @media (max-width: 860px) {
    .how__steps {
      flex-direction: column;
      gap: 1.5rem;
    }

    .step__connector {
      top: auto;
      right: auto;
      bottom: 0;
      left: 50%;
      transform: translate(-50%, 50%) rotate(90deg);
    }
  }

  @media (max-width: 480px) {
    .how__header {
      margin-bottom: 2.5rem;
    }

    .step {
      padding: 1.5rem 1.25rem;
    }

    .step__icon {
      width: 36px;
      height: 36px;
    }

    .step__title {
      font-size: 1rem;
    }

    .step__detail {
      font-size: 0.875rem;
    }

    .how__closing {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
    }
  }
</style>
