---
const steps = [
  {
    number: '01',
    title: 'Peça e diga onde você está.',
    detail: 'Abra o app, confirme sua localização.',
  },
  {
    number: '02',
    title: 'Veja o preço antes de confirmar.',
    detail: 'Sem surpresa, sem negociar — o valor aparece antes de você aceitar.',
  },
  {
    number: '03',
    title: 'Acompanhe a moto chegando até você.',
    detail: 'Rastreio em tempo real. Você sabe exatamente onde está o motoboy.',
  },
  {
    number: '04',
    title: 'Pague sem precisar ter dinheiro.',
    detail: 'Pagamento digital, seguro, sem troco, sem risco.',
  },
];
---

<section class="how" id="como-funciona" aria-labelledby="how-title">
  <div class="how__container">

    <div class="how__header">
      <p class="eyebrow reveal">Como funciona</p>
      <h2 class="section-title reveal delay-1" id="how-title">
        Sem ligação.<br />Sem esperar no escuro.
      </h2>
    </div>

    <div class="how__steps">
      {steps.map((step, i) => (
        <div class="step reveal" style={`transition-delay: ${(i + 1) * 0.12}s`}>
          <div class="step__number-col">
            <span class="step__number mono" aria-hidden="true">{step.number}</span>
            {i < steps.length - 1 && (
              <div class="step__connector" aria-hidden="true">
                <div class="step__connector-line"></div>
                <div class="step__connector-dot"></div>
              </div>
            )}
          </div>
          <div class="step__content">
            <h3 class="step__title">{step.title}</h3>
            <p class="step__detail">{step.detail}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="how__closing reveal">
      <div class="how__closing-bar" aria-hidden="true"></div>
      <p class="how__closing-text">
        Você sabe exatamente o que vai pagar e quando a moto chega.<br />
        <strong>Simples assim.</strong>
      </p>
      <div class="how__closing-bar" aria-hidden="true"></div>
    </div>

  </div>
</section>

<style>
  .how {
    padding: var(--section-pad-y) var(--section-pad-x);
    position: relative;
  }

  .how__container {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .how__header {
    margin-bottom: 4rem;
  }

  /* Steps */
  .how__steps {
    display: grid;
    gap: 0;
    margin-bottom: 5rem;
  }

  .step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0 2rem;
    align-items: start;
    padding-bottom: 2.5rem;
  }

  .step__number-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .step__number {
    font-size: 2.5rem;
    color: var(--accent);
    line-height: 1;
    flex-shrink: 0;
    width: 80px;
    text-align: center;
    padding: 0.75rem 0;
    position: relative;
  }

  .step__number::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    box-shadow: 0 0 20px rgba(244, 194, 13, 0.04);
  }

  .step__number {
    position: relative;
    z-index: 1;
  }

  .step__connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    padding: 0.5rem 0;
    min-height: 2rem;
  }

  .step__connector-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(to bottom, var(--accent), transparent);
    opacity: 0.3;
    min-height: 24px;
  }

  .step__connector-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.5;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.3); }
  }

  .step__content {
    padding-top: 0.625rem;
    padding-bottom: 2rem;
  }

  .step__title {
    font-size: 1.125rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .step__detail {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* Closing */
  .how__closing {
    display: flex;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  .how__closing-bar {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent));
    opacity: 0.2;
  }

  .how__closing-bar:last-child {
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .how__closing-text {
    font-size: 1.0625rem;
    color: var(--muted);
    flex-shrink: 0;
    max-width: 400px;
    line-height: 1.6;
  }

  .how__closing-text strong {
    color: var(--text);
  }

  @media (max-width: 480px) {
    .step {
      grid-template-columns: 56px 1fr;
      gap: 0 1rem;
    }

    .step__number {
      font-size: 1.5rem;
      width: 56px;
      padding: 0.625rem 0;
    }

    .step__content {
      padding-top: 0.5rem;
      padding-bottom: 1.5rem;
    }

    .step__title {
      font-size: 1rem;
    }

    .step__detail {
      font-size: 0.875rem;
    }

    .how__closing {
      flex-direction: column;
      gap: 1rem;
    }

    .how__closing-bar {
      width: 60px;
      flex: none;
    }
  }
</style>
