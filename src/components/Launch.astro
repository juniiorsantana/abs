---
const promises = [
  {
    title: "Motoboys daqui",
    detail:
      "Gente de Cáceres, cadastrada e identificada no app. Você sabe quem vai te buscar.",
    icon: "M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z",
  },
  {
    title: "Sem surpresa desde o dia um",
    detail:
      "Preço na tela antes de confirmar, piso de R$ 8 e valor travado até o fim da corrida.",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  },
  {
    title: "Suporte de verdade",
    detail:
      "Falou no WhatsApp, a gente responde. Sem robô, sem fila de espera.",
    icon: "M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z",
  },
];
---

<section class="launch" id="chegamos" aria-labelledby="launch-title">
  <div class="launch__sticky">
    <div class="launch__photo-stage" id="launch-photo-stage" aria-hidden="true">
      <div class="launch__photo-frame">
        <div class="launch__photo-img"></div>
      </div>
      <div class="launch__photo-dark"></div>
    </div>

    <div class="launch__bg" id="launch-bg" aria-hidden="true">
      <div class="launch__bg-grid"></div>
      <div class="launch__aurora"></div>
      <span class="launch__giant">CÁCERES</span>
    </div>

    <div class="launch__container" id="launch-container">
      <div class="launch__header" id="launch-header">
        <h2 class="section-title" id="launch-title">Chegamos em Cáceres.</h2>
      </div>

      <div class="launch__grid" id="launch-cards-grid">
        {
          promises.map((p, i) => (
            <div class="promise">
              <span class="promise__index mono" aria-hidden="true">
                0{i + 1}
              </span>
              <div class="promise__icon" aria-hidden="true">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d={p.icon} />
                </svg>
              </div>
              <h3 class="promise__title">{p.title}</h3>
              <p class="promise__detail">{p.detail}</p>
            </div>
          ))
        }
      </div>

      <div class="launch__actions">
        <a
          href="https://wa.me/5565996164735"
          class="btn btn--primary"
          target="_blank"
          rel="noopener noreferrer"
          id="cta-primeiros"
        >
          <span>Quero ser um dos primeiros</span>
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const section = document.getElementById("chegamos");
  const photoStage = document.getElementById("launch-photo-stage");
  const bg = document.getElementById("launch-bg");
  const container = document.getElementById("launch-container");
  const header = document.getElementById("launch-header");
  const title = document.getElementById("launch-title");
  const grid = document.getElementById("launch-cards-grid");
  const cta = document.getElementById("cta-primeiros");

  if (
    section &&
    photoStage &&
    bg &&
    container &&
    header &&
    title &&
    grid &&
    cta &&
    !prefersReduced
  ) {
    let ticking = false;

    // Distância entre o centro do título sozinho e a posição final do
    // título quando o bloco inteiro (título + cards + botão) está centralizado.
    // Recalculado no resize para se manter correto em qualquer largura de tela.
    let centerOffset = 0;
    const measureCenterOffset = () => {
      centerOffset = (container.offsetHeight - header.offsetHeight) / 2;
    };
    measureCenterOffset();
    window.addEventListener("resize", measureCenterOffset);

    const update = () => {
      const rect = section.getBoundingClientRect();
      const vh = window.innerHeight;

      if (rect.bottom < 0 || rect.top > vh) return;

      let progress = 0;
      if (rect.top <= 0) {
        progress = Math.abs(rect.top) / (rect.height - vh);
      }
      progress = Math.min(1, Math.max(0, progress));

      // 1. ANIMAÇÃO DA FOTO (0.0 a 0.35)
      // Cresce de 0.25 a 1.0 (ficando maior no início)
      const grow = Math.min(1, progress / 0.35);
      photoStage.style.setProperty("--grow", String(grow));

      // 2. PAUSA DA FOTO + ESCURECIMENTO (0.35 a 0.50)
      // A foto se mantém estática em 100% ocupando a tela, enquanto o fundo escurece para dar contraste
      const darkFactor = Math.min(1, Math.max(0, (progress - 0.25) / 0.25));
      photoStage.style.setProperty("--dark", String(darkFactor * 0.76));

      // Opacidade geral do background decorativo acompanha o final do grow
      bg.style.opacity = String(
        Math.min(1, Math.max(0, (progress - 0.35) / 0.15)),
      );

      // 3. TÍTULO SOZINHO E CENTRALIZADO (0.50 a 0.66)
      // Entra de baixo para cima já deslocado para o centro vertical da tela
      const titleIn = Math.min(1, Math.max(0, (progress - 0.5) / 0.16));
      title.style.opacity = String(titleIn);

      // 3b. TÍTULO SOBE JUNTO COM OS OUTROS ELEMENTOS (0.76 a 0.90)
      // Depois da pausa centralizado, sobe até sua posição final enquanto os cards entram
      const titleRise = Math.min(1, Math.max(0, (progress - 0.76) / 0.14));
      const titleEnterY = (1 - titleIn) * 40;
      const titleCenterY = (1 - titleRise) * centerOffset;
      title.style.transform = `translateY(${titleEnterY + titleCenterY}px)`;

      // 4. SEQUÊNCIA DOS CARDS (0.78 a 0.92)
      // Os 3 cards sobem juntos enquanto o título termina de subir
      const gridProgress = Math.min(1, Math.max(0, (progress - 0.78) / 0.14));
      grid.style.opacity = String(gridProgress);
      grid.style.transform = `translateY(${(1 - gridProgress) * 40}px)`;

      // 5. SEQUÊNCIA DO BOTÃO (0.92 a 1.0)
      // O botão surge por último, fechando a seção
      const ctaProgress = Math.min(1, Math.max(0, (progress - 0.92) / 0.08));
      cta.style.opacity = String(ctaProgress);
      cta.style.transform = `translateY(${(1 - ctaProgress) * 30}px)`;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            update();
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true },
    );

    update();
  }

  // Efeito Magnético no CTA Centralizado
  if (cta && !prefersReduced && window.matchMedia("(hover: hover)").matches) {
    cta.addEventListener("mousemove", (e) => {
      const r = cta.getBoundingClientRect();
      const x = e.clientX - r.left - r.width / 2;
      const y = e.clientY - r.top - r.height / 2;
      cta.style.transition = "transform 0.2s cubic-bezier(0.16, 1, 0.3, 1)";
      cta.style.transform = `translate(${x * 0.2}px, ${y * 0.25}px)`;
    });

    cta.addEventListener("mouseleave", () => {
      cta.style.transition = "transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1)";
      cta.style.transform = "";
    });
  }

  // Microinteração dos cards: tilt 3D + spotlight seguindo o cursor.
  // Entrada rápida (resposta imediata ao gesto), saída lenta (assentamento "caro").
  if (!prefersReduced && window.matchMedia("(hover: hover)").matches) {
    const ENTER_TRANSITION =
      "transform 0.15s ease-out, box-shadow 0.35s ease, border-color 0.3s ease";
    const EXIT_TRANSITION =
      "transform 1s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.8s ease, border-color 0.6s ease";

    document.querySelectorAll(".promise").forEach((card) => {
      const el = card as HTMLElement;
      let frame: number | null = null;

      el.addEventListener("mouseenter", () => {
        el.style.transition = ENTER_TRANSITION;
      });

      el.addEventListener("mousemove", (e) => {
        const r = el.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width;
        const py = (e.clientY - r.top) / r.height;

        if (frame) cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          const rx = (0.5 - py) * 7;
          const ry = (px - 0.5) * 9;
          el.style.setProperty("--mx", `${px * 100}%`);
          el.style.setProperty("--my", `${py * 100}%`);
          el.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-6px) scale(1.015)`;
        });
      });

      el.addEventListener("mouseleave", () => {
        if (frame) cancelAnimationFrame(frame);
        el.style.transition = EXIT_TRANSITION;
        el.style.transform = "";
        el.style.setProperty("--mx", "50%");
        el.style.setProperty("--my", "50%");
      });
    });
  }
</script>

<style>
  .launch {
    height: 380vh; /* Mantém a pista longa para garantir suavidade nas pausas */
    position: relative;
    background-color: #0b0b0c;
  }

  .launch__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    padding: var(--section-pad-y) var(--section-pad-x);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  /* Configurações da Foto de Cáceres */
  .launch__photo-stage {
    --grow: 0;
    --dark: 0;
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .launch__photo-frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
    /* Inicia em 0.25 (bem maior) e escala até 1.0 */
    transform: scale(calc(0.25 + var(--grow) * 0.75));
    border-radius: calc((1 - var(--grow)) * 40px);
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.8);
  }

  .launch__photo-img {
    position: absolute;
    inset: -5%;
    background: url("/caceres.jpg") center 58% / cover no-repeat;
    background: url("/caceres.avif") center 58% / cover no-repeat;
    filter: saturate(0.85) contrast(1.05) brightness(0.95);
  }

  .launch__photo-dark {
    position: absolute;
    inset: 0;
    background: rgba(11, 11, 12, var(--dark, 0));
  }

  /* Elementos estruturais e de conteúdo inicializados invisíveis para o JS controlar */
  .launch__bg,
  #launch-title,
  #launch-cards-grid,
  #cta-primeiros {
    opacity: 0;
    will-change: transform, opacity;
  }

  .launch__container {
    max-width: var(--container-max);
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Centralização do Cabeçalho sem Subtítulos */
  .launch__header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 100%;
  }

  .launch__header .section-title {
    font-size: clamp(1.8rem, 5.5vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    text-align: center;
  }

  @media (min-width: 993px) {
    .launch__header .section-title {
      white-space: nowrap;
    }
  }

  .launch__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    width: 100%;
    margin-bottom: 4rem;
  }

  /* Posicionamento do Botão Centralizado */
  .launch__actions {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  #cta-primeiros {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  /* Estilização dos Cards Modulares */
  .promise {
    --mx: 50%;
    --my: 50%;
    background: linear-gradient(
      145deg,
      rgba(242, 240, 234, 0.04) 0%,
      rgba(242, 240, 234, 0.01) 100%
    );
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 2rem 1.75rem;
    position: relative;
    overflow: hidden;
    box-shadow:
      0 15px 35px -12px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(242, 240, 234, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    will-change: transform;
    transition:
      border-color 0.6s ease,
      transform 0.8s var(--ease-out-expo),
      box-shadow 0.6s ease;
  }

  /* Trilho de luz que acompanha o cursor */
  .promise::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      260px circle at var(--mx) var(--my),
      rgba(244, 194, 13, 0.14),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.6s var(--ease-out-expo);
    pointer-events: none;
  }

  .promise:hover::before {
    opacity: 1;
    transition: opacity 0.25s ease;
  }

  /* Filete superior que se traça na entrada e recolhe devagar na saída */
  .promise::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 1;
    background: linear-gradient(90deg, var(--accent), transparent 80%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.8s var(--ease-out-expo);
  }

  .promise:hover::after {
    transform: scaleX(1);
    transition: transform 0.45s var(--ease-out-expo);
  }

  .promise:hover {
    box-shadow:
      0 25px 45px -12px rgba(0, 0, 0, 0.7),
      inset 0 1px 0 rgba(242, 240, 234, 0.08);
    border-color: rgba(244, 194, 13, 0.3);
  }

  .promise__index {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    z-index: 1;
    font-size: 0.6875rem;
    color: var(--muted);
    opacity: 0.4;
    letter-spacing: 0.05em;
    transition:
      color 0.6s ease,
      opacity 0.6s ease,
      transform 0.7s var(--ease-out-expo);
  }

  .promise:hover .promise__index {
    color: var(--accent);
    opacity: 0.9;
    transform: translateY(-2px);
    transition:
      color 0.25s ease,
      opacity 0.25s ease,
      transform 0.3s var(--ease-out-expo);
  }

  .promise__icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: rgba(244, 194, 13, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
    transition:
      background 0.6s ease,
      transform 0.7s var(--ease-out-expo);
  }

  .promise:hover .promise__icon {
    background: rgba(244, 194, 13, 0.16);
    transform: scale(1.08) rotate(-4deg);
    transition:
      background 0.3s ease,
      transform 0.4s var(--ease-spring);
  }

  .promise__title {
    font-size: 1.125rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.6rem;
    position: relative;
    z-index: 1;
  }

  .promise__detail {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  /* Backgrounds e Aurora */
  .launch__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .launch__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(244, 194, 13, 0.02) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(244, 194, 13, 0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent,
      black 25%,
      black 75%,
      transparent
    );
    mask-image: linear-gradient(
      to bottom,
      transparent,
      black 25%,
      black 75%,
      transparent
    );
  }

  .launch__aurora {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 75vw;
    height: 55vh;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      rgba(244, 194, 13, 0.06),
      transparent 65%
    );
    filter: blur(80px);
  }

  .launch__giant {
    position: absolute;
    bottom: -0.05em;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(6rem, 18vw, 18rem);
    line-height: 0.75;
    letter-spacing: -0.05em;
    white-space: nowrap;
    color: transparent;
    -webkit-text-stroke: 1px rgba(244, 194, 13, 0.05);
    background: linear-gradient(
      180deg,
      rgba(242, 240, 234, 0.03) 0%,
      transparent 70%
    );
    -webkit-background-clip: text;
    background-clip: text;
    user-select: none;
    opacity: 0.25;
  }

  @media (max-width: 992px) {
    .launch__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .launch__header {
      margin-bottom: 2.5rem;
    }
  }

  /* Fallback Acessibilidade */
  @media (prefers-reduced-motion: reduce) {
    .launch {
      height: auto;
    }
    .launch__sticky {
      position: relative;
      height: auto;
      padding: 4rem 2rem;
    }
    .launch__bg,
    #launch-title,
    #launch-cards-grid,
    #cta-primeiros {
      opacity: 1;
      transform: none;
    }
    .launch__photo-frame {
      transform: scale(1);
      border-radius: 0;
    }
    .launch__photo-dark {
      background: rgba(11, 11, 12, 0.75);
    }
  }
</style>
