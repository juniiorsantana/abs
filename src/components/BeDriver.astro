---
const slides = [
  {
    label: 'Você escolhe seu horário',
    detail: 'De manhã, à noite ou só no fim de semana — roda quando fizer sentido pra você.',
  },
  {
    label: 'Corridas e entregas no app',
    detail: 'A chamada chega no seu celular quando tem gente ou encomenda perto de você.',
  },
  {
    label: 'Fica com 90% de cada corrida',
    detail: 'Rodou, recebeu. O valor cai direto pra você, sem espera.',
  },
];
---

<section class="driver section--surface" id="motoboy" aria-labelledby="driver-title">
  <div class="driver__speed" aria-hidden="true"></div>

  <div class="driver__container">
    <div class="driver__main">
      <p class="eyebrow reveal">Para motoboys</p>
      <h2 class="section-title reveal delay-1" id="driver-title">
        Transforme Km's<br />em renda extra.
      </h2>
      <p class="driver__text reveal delay-2">
        Você já tem a moto. A gente manda corridas e entregas perto de você.
      </p>

      <!-- Card rotativo de benefícios -->
      <button
        class="slider-card reveal delay-3"
        id="benefit-card"
        type="button"
        aria-live="polite"
        aria-label="Benefícios de rodar com o ABS. Toque para ver o próximo."
      >
        <div class="slider-card__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8l3 3 7-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <div class="slider-card__viewport">
          {slides.map((s, i) => (
            <div class={`slider-card__slide${i === 0 ? ' active' : ''}`} data-slide={i}>
              <p class="slider-card__label">{s.label}</p>
              <p class="slider-card__detail">{s.detail}</p>
            </div>
          ))}
        </div>

        <div class="slider-card__dots" aria-hidden="true">
          {slides.map((_, i) => (
            <span class={`slider-card__dot${i === 0 ? ' active' : ''}`} data-dot={i}></span>
          ))}
        </div>
      </button>

      <a
        href="/seja-motoboy"
        class="btn btn--primary reveal delay-4"
        id="cta-motoboy"
      >
        <span>Quero rodar com o ABS</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Calculadora de renda extra -->
    <aside class="driver__panel reveal delay-2" aria-label="Calculadora de renda estimada">
      <div class="driver__panel-header">
        <span class="driver__panel-label">Simule seu ganho</span>
        <span class="driver__panel-status mono" aria-hidden="true">● AO VIVO</span>
      </div>

      <div class="driver__panel-body">
        <div class="calc__row">
          <div class="calc__row-top">
            <label for="calc-hours">Horas rodadas por dia</label>
            <span class="calc__row-value mono" id="calc-hours-value">2h</span>
          </div>
          <input type="range" id="calc-hours" min="1" max="10" step="1" value="2" aria-describedby="calc-result-label" />
        </div>

        <div class="calc__row">
          <div class="calc__row-top">
            <label for="calc-rides">Corridas por hora</label>
            <span class="calc__row-value mono" id="calc-rides-value">4</span>
          </div>
          <input type="range" id="calc-rides" min="1" max="6" step="1" value="4" aria-describedby="calc-result-label" />
        </div>

        <div class="calc__row">
          <div class="calc__row-top">
            <label for="calc-fare">Valor médio da corrida</label>
            <span class="calc__row-value mono" id="calc-fare-value">R$12</span>
          </div>
          <input type="range" id="calc-fare" min="8" max="18" step="1" value="12" aria-describedby="calc-result-label" />
        </div>

        <div class="calc__formula mono" aria-hidden="true">
          <span id="calc-hours-echo">2h</span>
          <span class="calc__formula-op">×</span>
          <span id="calc-rides-echo">4</span>
          <span class="calc__formula-op">×</span>
          <span id="calc-fare-echo">R$12</span>
        </div>

        <div class="calc__result">
          <p class="calc__result-label" id="calc-result-label">Você pode ganhar</p>
          <div class="calc__result-value">
            <span class="calc__result-currency mono">R$</span>
            <span class="mono" id="calc-result">96</span>
          </div>
          <p class="calc__result-sub">por dia, em média</p>
        </div>
      </div>
    </aside>
  </div>
</section>

<script>
  // ── Calculadora ──────────────────────────────────────────────────────────
  const hoursInput = document.getElementById('calc-hours') as HTMLInputElement | null;
  const ridesInput = document.getElementById('calc-rides') as HTMLInputElement | null;
  const fareInput = document.getElementById('calc-fare') as HTMLInputElement | null;
  const hoursValue = document.getElementById('calc-hours-value');
  const ridesValue = document.getElementById('calc-rides-value');
  const fareValue = document.getElementById('calc-fare-value');
  const hoursEcho = document.getElementById('calc-hours-echo');
  const ridesEcho = document.getElementById('calc-rides-echo');
  const fareEcho = document.getElementById('calc-fare-echo');
  const result = document.getElementById('calc-result');

  function setFill(input: HTMLInputElement) {
    const min = Number(input.min);
    const max = Number(input.max);
    const pct = ((Number(input.value) - min) / (max - min)) * 100;
    input.style.setProperty('--fill', `${pct}%`);
  }

  function updateCalc() {
    if (
      !hoursInput || !ridesInput || !fareInput ||
      !hoursValue || !ridesValue || !fareValue ||
      !hoursEcho || !ridesEcho || !fareEcho || !result
    ) return;

    const hours = Number(hoursInput.value);
    const rides = Number(ridesInput.value);
    const fare = Number(fareInput.value);
    const total = hours * rides * fare;

    setFill(hoursInput);
    setFill(ridesInput);
    setFill(fareInput);

    hoursValue.textContent = `${hours}h`;
    ridesValue.textContent = `${rides}`;
    fareValue.textContent = `R$${fare}`;
    hoursEcho.textContent = `${hours}h`;
    ridesEcho.textContent = `${rides}`;
    fareEcho.textContent = `R$${fare}`;
    result.textContent = total.toLocaleString('pt-BR');
  }

  hoursInput?.addEventListener('input', updateCalc);
  ridesInput?.addEventListener('input', updateCalc);
  fareInput?.addEventListener('input', updateCalc);
  updateCalc();

  // ── Card rotativo de benefícios ──────────────────────────────────────────
  const card = document.getElementById('benefit-card');
  const cardSlides = document.querySelectorAll<HTMLElement>('.slider-card__slide');
  const cardDots = document.querySelectorAll<HTMLElement>('.slider-card__dot');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (card && cardSlides.length > 0) {
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function show(index: number) {
      cardSlides.forEach((s, i) => s.classList.toggle('active', i === index));
      cardDots.forEach((d, i) => d.classList.toggle('active', i === index));
      current = index;
    }

    function next() {
      show((current + 1) % cardSlides.length);
    }

    function startTimer() {
      if (prefersReduced) return;
      if (timer) clearInterval(timer);
      timer = setInterval(next, 4500);
    }

    card.addEventListener('click', () => {
      next();
      startTimer();
    });

    startTimer();
  }
</script>

<style>
  .driver {
    display: flex;
    align-items: center;
    padding: 4rem var(--section-pad-x);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 920px) {
    .driver {
      min-height: 0;
      max-height: none;
      padding: 5rem var(--section-pad-x);
    }
  }

  /* Linhas de velocidade sutis no fundo */
  .driver__speed {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -6deg,
      transparent 0,
      transparent 140px,
      rgba(244, 194, 13, 0.04) 140px,
      rgba(244, 194, 13, 0.04) 141px
    );
    mask-image: radial-gradient(ellipse at 70% 50%, black 20%, transparent 75%);
    pointer-events: none;
  }

  .driver__container {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 920px) {
    .driver__container {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 4rem;
    }
  }

  .driver__main .section-title {
    margin-bottom: 1.25rem;
  }

  .driver__text {
    font-size: 1.0625rem;
    color: var(--muted);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  /* ── Card rotativo ─────────────────────────────────────────────────────── */

  .slider-card {
    display: block;
    width: 100%;
    max-width: 560px;
    text-align: left;
    font-family: inherit;
    cursor: pointer;
    padding: 1.25rem 1.5rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .slider-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--accent);
    opacity: 0.6;
    transition: opacity 0.25s ease;
  }

  .slider-card:hover {
    border-color: rgba(244, 194, 13, 0.3);
    box-shadow: 0 0 24px rgba(244, 194, 13, 0.06);
  }

  .slider-card:hover::before {
    opacity: 1;
  }

  .slider-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .slider-card__icon {
    position: absolute;
    top: 1.25rem;
    left: 1.5rem;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(244, 194, 13, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }

  .slider-card__viewport {
    position: relative;
    min-height: 4.25rem;
    margin-left: 2.75rem;
  }

  .slider-card__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
    pointer-events: none;
  }

  .slider-card__slide.active {
    opacity: 1;
    transform: translateY(0);
  }

  .slider-card__label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .slider-card__detail {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .slider-card__dots {
    display: flex;
    gap: 0.375rem;
    margin-top: 0.875rem;
    margin-left: 2.75rem;
  }

  .slider-card__dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    background: var(--surface-2);
    transition: background 0.3s ease, width 0.3s var(--ease-out-expo);
  }

  .slider-card__dot.active {
    background: var(--accent);
    width: 18px;
  }

  /* ── Calculadora de renda ──────────────────────────────────────────────── */

  .driver__panel {
    background: var(--bg);
    border: 1px solid var(--border-solid);
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.35);
  }

  .driver__panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
  }

  .driver__panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  .driver__panel-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .driver__panel-status {
    font-size: 0.6875rem;
    color: #4ade80;
    letter-spacing: 0.08em;
  }

  .driver__panel-body {
    padding: 1.5rem 1.75rem 0.5rem;
  }

  .calc__row {
    margin-bottom: 1.25rem;
  }

  .calc__row-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.625rem;
  }

  .calc__row-top label {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .calc__row-value {
    font-size: 0.8125rem;
    color: var(--accent);
    background: rgba(244, 194, 13, 0.08);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.2rem 0.625rem;
    min-width: 2.75rem;
    text-align: center;
  }

  /* ── Slider customizado ── */
  input[type='range'] {
    --fill: 50%;
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 20px;
    background: transparent;
    cursor: pointer;
    display: block;
  }

  /* Trilha: parte percorrida em amarelo, resto apagado */
  input[type='range']::-webkit-slider-runnable-track {
    height: 4px;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      var(--accent) var(--fill),
      var(--surface-2) var(--fill)
    );
  }

  input[type='range']::-moz-range-track {
    height: 4px;
    border-radius: 2px;
    background: var(--surface-2);
  }

  input[type='range']::-moz-range-progress {
    height: 4px;
    border-radius: 2px;
    background: var(--accent);
  }

  /* Thumb */
  input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    margin-top: -7px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 1px var(--border-solid), 0 0 12px rgba(244, 194, 13, 0.35);
    transition: box-shadow 0.2s ease, transform 0.15s var(--ease-spring);
  }

  input[type='range']::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 1px var(--border-solid), 0 0 12px rgba(244, 194, 13, 0.35);
    transition: box-shadow 0.2s ease, transform 0.15s var(--ease-spring);
  }

  input[type='range']:hover::-webkit-slider-thumb,
  input[type='range']:active::-webkit-slider-thumb {
    transform: scale(1.15);
    box-shadow: 0 0 0 1px var(--border-solid), 0 0 20px rgba(244, 194, 13, 0.55);
  }

  input[type='range']:hover::-moz-range-thumb,
  input[type='range']:active::-moz-range-thumb {
    transform: scale(1.15);
    box-shadow: 0 0 0 1px var(--border-solid), 0 0 20px rgba(244, 194, 13, 0.55);
  }

  input[type='range']:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .calc__formula {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text);
    padding: 0.625rem 1rem;
    background: var(--surface);
    border: 1px dashed var(--border-solid);
    border-radius: var(--radius-sm);
    margin: 1.25rem 0;
  }

  .calc__formula-op {
    color: var(--accent);
    font-size: 0.75rem;
  }

  .calc__result {
    text-align: center;
    padding-bottom: 1.5rem;
  }

  .calc__result-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
  }

  .calc__result-value {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    line-height: 1;
  }

  .calc__result-currency {
    font-size: 1.5rem;
    color: var(--accent);
    opacity: 0.6;
    margin-top: 0.625rem;
    margin-right: 0.25rem;
  }

  #calc-result {
    font-size: clamp(2.75rem, 7vw, 4rem);
    color: var(--accent);
    line-height: 1;
    text-shadow: 0 0 32px rgba(244, 194, 13, 0.25);
  }

  .calc__result-sub {
    font-size: 0.875rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  @media (max-width: 480px) {
    .driver__panel-body {
      padding: 1.5rem 1.25rem 0.5rem;
    }

    .driver__panel-header {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .slider-card__viewport {
      min-height: 5.5rem;
    }
  }
</style>
