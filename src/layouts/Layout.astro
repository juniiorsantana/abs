---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Vai de ABS — Moto táxi via app em Cáceres',
  description = 'A forma mais moderna de se mover em Cáceres. Veja o preço antes, acompanhe a moto e pague sem dinheiro.',
} = Astro.props;

// TODO: trocar pelo domínio real quando o site for publicado
const SITE_URL = 'https://vaideabs.com.br';
const canonical = new URL(Astro.url.pathname, SITE_URL).href;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Vai de ABS',
  description:
    'Moto táxi via app em Cáceres, MT. Preço visível antes de confirmar, rastreio em tempo real e pagamento digital.',
  url: SITE_URL,
  telephone: '+55-65-99616-4735',
  image: `${SITE_URL}/og-image.png`,
  priceRange: 'R$',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Cáceres',
    addressRegion: 'MT',
    addressCountry: 'BR',
  },
  areaServed: {
    '@type': 'City',
    name: 'Cáceres',
  },
  sameAs: ['https://www.instagram.com/pedeabscaceres/'],
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE_URL}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Vai de ABS" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}/og-image.png`} />

    <meta name="theme-color" content="#0B0B0C" />

    <!-- Dados estruturados: negócio local -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <!-- Scroll progress line -->
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>

    <!-- Navbar -->
    <nav class="navbar" id="navbar" role="navigation" aria-label="Navegação principal">
      <div class="navbar__inner">
        <a href="/#hero" class="navbar__brand" aria-label="Vai de ABS - Início">
          Vai de ABS<span class="navbar__dot">.</span>
        </a>
        <div class="navbar__links navbar__links--desktop">
          <a href="/#como-funciona" class="navbar__link">Como funciona</a>
          <a href="/#motoboy" class="navbar__link">Seja motoboy</a>
          <a href="/#precos" class="navbar__link">Preços</a>
          <button type="button" class="navbar__cta" data-open-app-modal>Pedir corrida</button>
        </div>

        <button
          class="navbar__toggle"
          id="nav-toggle"
          aria-expanded="false"
          aria-controls="nav-mobile"
          aria-label="Abrir menu"
        >
          <span class="navbar__toggle-line"></span>
          <span class="navbar__toggle-line"></span>
          <span class="navbar__toggle-line"></span>
        </button>
      </div>

      <div class="navbar__mobile" id="nav-mobile" aria-hidden="true">
        <a href="/#como-funciona" class="navbar__mobile-link">Como funciona</a>
        <a href="/#motoboy" class="navbar__mobile-link">Seja motoboy</a>
        <a href="/#precos" class="navbar__mobile-link">Preços</a>
        <button type="button" class="navbar__mobile-cta btn btn--primary" data-open-app-modal>Pedir corrida</button>
      </div>
    </nav>

    <slot />

    <!-- Modal de download do app -->
    <div class="app-modal" id="app-modal" aria-hidden="true">
      <div class="app-modal__overlay" data-close-app-modal></div>
      <div
        class="app-modal__panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="app-modal-title"
      >
        <button type="button" class="app-modal__close" data-close-app-modal aria-label="Fechar">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>

        <p class="eyebrow">Baixe o app</p>
        <h2 class="app-modal__title" id="app-modal-title">Peça sua corrida pelo app.</h2>
        <p class="app-modal__sub">Disponível pra iOS e Android. É rápido, é grátis.</p>

        <div class="app-modal__stores">
          <a
            href="https://apps.apple.com/br/app/abs-pro/id6754334766"
            class="app-modal__store app-modal__store--light"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="app-modal__store-icon" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
              <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
            </svg>
            <span class="app-modal__store-text"><em>Baixar na</em>App Store</span>
          </a>
          <a
            href="https://play.google.com/store/apps/details?id=br.com.devbase.abspro"
            class="app-modal__store app-modal__store--dark"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="app-modal__store-icon" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
              <path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z"/>
            </svg>
            <span class="app-modal__store-text"><em>Disponível no</em>Google Play</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Floating WhatsApp button -->
    <a
      href="https://wa.me/5565996164735"
      class="whatsapp-float"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Falar no WhatsApp"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2zm5.83 14.17c-.24.68-1.42 1.33-1.94 1.4-.5.07-1.05.1-1.7-.11-.39-.12-.9-.28-1.55-.55-2.73-1.18-4.51-3.93-4.65-4.11-.14-.18-1.11-1.47-1.11-2.81 0-1.33.7-1.98.95-2.25.24-.27.53-.34.71-.34.18 0 .35 0 .5.01.16.01.38-.06.59.45.24.58.81 2.01.88 2.16.07.15.12.32.02.52-.09.19-.14.31-.28.48-.14.17-.29.37-.42.5-.14.14-.28.28-.12.56.16.28.71 1.17 1.53 1.9 1.05.94 1.94 1.23 2.22 1.37.28.14.44.12.6-.07.16-.19.68-.79.86-1.06.18-.27.36-.22.6-.13.24.09 1.53.72 1.79.85.26.13.44.19.5.3.06.11.06.63-.18 1.31z"/>
      </svg>
    </a>

    <script>
      import Lenis from 'lenis';

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        const lenis = new Lenis({
          duration: 1.8,
          easing: (t: number) => 1 - Math.pow(1 - t, 4),
          smoothWheel: true,
          wheelMultiplier: 0.75,
          touchMultiplier: 1,
        });

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        document.querySelectorAll('a[href*="#"]').forEach((link) => {
          link.addEventListener('click', (e) => {
            const href = link.getAttribute('href') || '';
            const [path, hash] = href.split('#');
            if (!hash) return;
            if (path && path !== window.location.pathname) return;

            const target = document.getElementById(hash);
            if (!target) return;

            e.preventDefault();
            lenis.scrollTo(target, { offset: -72 });
          });
        });
      }

      // ─── Modal de download do app ───────────────────────────────────────────
      const appModal = document.getElementById('app-modal');
      const openTriggers = document.querySelectorAll('[data-open-app-modal]');
      const closeTriggers = appModal?.querySelectorAll('[data-close-app-modal]');

      function openAppModal() {
        if (!appModal) return;
        appModal.classList.add('open');
        appModal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeAppModal() {
        if (!appModal) return;
        appModal.classList.remove('open');
        appModal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      openTriggers.forEach((trigger) => {
        trigger.addEventListener('click', openAppModal);
      });

      closeTriggers?.forEach((trigger) => {
        trigger.addEventListener('click', closeAppModal);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && appModal?.classList.contains('open')) {
          closeAppModal();
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0B0B0C;
    --accent: #F4C20D;
    --text: #F2F0EA;
    --surface: #1A1A1C;
    --surface-2: #252527;
    --muted: #8A8A8E;
    --border: rgba(244, 194, 13, 0.12);
    --border-solid: rgba(244, 194, 13, 0.4);

    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);

    --section-pad-y: 7rem;
    --section-pad-x: 1.5rem;
    --container-max: 860px;
    --radius-sm: 4px;
    --radius-md: 8px;
  }

  @media (max-width: 768px) {
    :root {
      --section-pad-y: 4.5rem;
      --section-pad-x: 1.25rem;
    }
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html.lenis {
    height: auto;
  }

  html.lenis-smooth {
    scroll-behavior: auto;
  }

  .lenis.lenis-smooth iframe {
    pointer-events: none;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* Grain texture overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 10;
    opacity: 0.35;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .mono {
    font-family: var(--font-mono);
    font-weight: 700;
  }

  /* Scroll progress */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background: var(--accent);
    z-index: 1000;
    width: 0%;
    transition: width 0.1s linear;
    box-shadow: 0 0 8px rgba(244, 194, 13, 0.6);
  }

  /* Navbar */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 1.5rem;
    transition: background 0.3s ease, backdrop-filter 0.3s ease, border-bottom 0.3s ease;
    border-bottom: 1px solid transparent;
  }

  .navbar.scrolled {
    background: rgba(11, 11, 12, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--border);
  }

  .navbar__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar__brand {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.125rem;
    letter-spacing: -0.02em;
    transition: opacity 0.2s ease;
  }

  .navbar__brand:hover {
    opacity: 0.8;
  }

  .navbar__dot {
    color: var(--accent);
    animation: pulse-led 2s ease-in-out infinite;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .navbar__link {
    font-size: 0.875rem;
    color: var(--muted);
    transition: color 0.2s ease;
    font-weight: 500;
  }

  .navbar__link:hover {
    color: var(--text);
  }

  .navbar__cta {
    font-size: 0.875rem;
    font-weight: 600;
    background: var(--accent);
    color: var(--bg);
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-sm);
    transition: box-shadow 0.25s ease, transform 0.15s var(--ease-spring);
  }

  .navbar__cta:hover {
    box-shadow: 0 0 20px rgba(244, 194, 13, 0.45);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .navbar__links--desktop {
      display: none;
    }
    .navbar__toggle {
      display: flex;
    }
  }

  /* Hamburger toggle */
  .navbar__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 5px;
    z-index: 110;
  }

  .navbar__toggle-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    transition: transform 0.3s var(--ease-out-expo), opacity 0.3s ease;
    border-radius: 1px;
  }

  .navbar__toggle[aria-expanded="true"] .navbar__toggle-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .navbar__toggle[aria-expanded="true"] .navbar__toggle-line:nth-child(2) {
    opacity: 0;
  }

  .navbar__toggle[aria-expanded="true"] .navbar__toggle-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile overlay */
  .navbar__mobile {
    position: fixed;
    inset: 0;
    background: rgba(11, 11, 12, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    z-index: 99;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s var(--ease-out-expo), visibility 0.35s;
  }

  .navbar__mobile[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .navbar__mobile-link {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--muted);
    transition: color 0.2s ease, transform 0.3s var(--ease-out-expo);
    transform: translateY(20px);
  }

  .navbar__mobile[aria-hidden="false"] .navbar__mobile-link,
  .navbar__mobile[aria-hidden="false"] .navbar__mobile-cta {
    transform: translateY(0);
  }

  .navbar__mobile-link:nth-child(1) { transition-delay: 0.05s; }
  .navbar__mobile-link:nth-child(2) { transition-delay: 0.1s; }
  .navbar__mobile-link:nth-child(3) { transition-delay: 0.15s; }
  .navbar__mobile-cta { transition-delay: 0.2s; }

  .navbar__mobile-link:hover,
  .navbar__mobile-link:focus {
    color: var(--text);
  }

  .navbar__mobile-cta {
    margin-top: 1rem;
    font-size: 1rem;
    padding: 1rem 2rem;
    transform: translateY(20px);
    transition: box-shadow 0.25s ease, transform 0.3s var(--ease-out-expo);
  }

  /* Reveal animations */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s var(--ease-out-expo), transform 0.7s var(--ease-out-expo);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-left {
    opacity: 0;
    transform: translateX(-32px);
    transition: opacity 0.7s var(--ease-out-expo), transform 0.7s var(--ease-out-expo);
  }

  .reveal-left.visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* Stagger delays */
  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }
  .delay-4 { transition-delay: 0.4s; }
  .delay-5 { transition-delay: 0.5s; }
  .delay-6 { transition-delay: 0.6s; }

  /* Section divider */
  .section-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.2;
  }

  /* Keyframes */
  @keyframes pulse-led {
    0%, 100% { opacity: 1; text-shadow: 0 0 0 transparent; }
    50% { opacity: 0.6; text-shadow: 0 0 16px var(--accent), 0 0 32px rgba(244, 194, 13, 0.4); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideWidth {
    from { width: 0; }
    to { width: 100%; }
  }

  /* ── Global reusable classes ──────────────────────────────────────────────── */

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    display: block;
  }

  .section-title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 900;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.9rem 1.75rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: box-shadow 0.25s ease, transform 0.2s var(--ease-spring);
    border: none;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    text-decoration: none;
  }

  .btn--primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn--primary:hover {
    box-shadow: 0 0 32px rgba(244, 194, 13, 0.5);
    transform: translateY(-2px);
  }

  .btn--primary:active {
    transform: translateY(0);
  }

  .btn--secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid rgba(242, 240, 234, 0.2);
  }

  .btn--secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  /* ── Section transitions ────────────────────────────────────────────────── */

  .section--surface {
    background: var(--surface);
    position: relative;
  }

  .section--surface::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, var(--bg), var(--surface));
    pointer-events: none;
    z-index: 1;
  }

  .section--surface::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to top, var(--bg), var(--surface));
    pointer-events: none;
    z-index: 1;
  }

  /* Floating WhatsApp button */
  .whatsapp-float {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: linear-gradient(145deg, #2fe374, #20b358);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
